{
  "rules": {
    "boards": {
      "main": {
        "items":    { ".read": "auth != null", ".write": "auth != null" },
        "presence": { ".read": "auth != null", ".write": "auth != null" },
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
        }
      }
    },
    "roles": {
      ".read": "auth != null",
      "$uid": { ".write": "$uid === auth.uid" }
    }
  }
}